# Optional backend database location.
# If unset, the backend stores SQLite data at backend/paneltwin.db.
PANELTWIN_DB_PATH=backend/paneltwin.db

# Optional Vite development proxy target.
# Use this when the FastAPI backend runs on a non-default port.
PANELTWIN_API_TARGET=http://127.0.0.1:8000

# Static portfolio demo mode for GitHub Pages.
# The normal local app should leave this unset or false.
VITE_DEMO_MODE=false

# Optional Vite base path.
# GitHub Pages project sites use /REPOSITORY_NAME/.
VITE_BASE_PATH=/
